<launch>

  <!-- ── Câmera Astra ──────────────────────────────────────── -->
  <include file="$(find astra_camera)/launch/dabai_u3.launch"/>

  <!-- ── Nó 1: Detector de cor ──────────────────────────────── -->
  <node name="color_detector" pkg="follower_limo" type="color_detector.py" output="screen">
    <rosparam file="$(find follower_limo)/config/params.yaml" command="load" ns="color_detector"/>
  </node>

  <!-- ── Nó 2: Leitor do LiDAR ──────────────────────────────── -->
  <node name="lidar_reader" pkg="follower_limo" type="lidar_reader.py" output="screen">
    <rosparam file="$(find follower_limo)/config/params.yaml" command="load" ns="lidar_reader"/>
  </node>

  <!-- ── Nó 3: Fusão de sensores ────────────────────────────── -->
  <node name="sensor_fusion" pkg="follower_limo" type="sensor_fusion.py" output="screen">
    <rosparam file="$(find follower_limo)/config/params.yaml" command="load" ns="sensor_fusion"/>
  </node>

  <!-- ── Nó 4: Controlador ───────────────────────────────────── -->
  <node name="follower_controller" pkg="follower_limo" type="follower_controller.py" output="screen">
    <rosparam file="$(find follower_limo)/config/params.yaml" command="load" ns="follower_controller"/>
  </node>

</launch>